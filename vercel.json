{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api-search",
      "destination": "/api/search.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}